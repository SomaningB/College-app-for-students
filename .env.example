# ============================================
# College App - Environment Configuration
# ============================================
# Copy this file to backend/.env and fill in your values.
# NEVER commit the actual .env file to git.

# Database
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=college_app

# JWT Secret - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Services (optional - for AI features)
OPENAI_API_KEY=sk-your-openai-api-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Email (Brevo/Sendinblue)
BREVO_API_KEY=your-brevo-api-key
FROM_EMAIL=noreply@collegeapp.com
FROM_NAME="College App"

# App
APP_URL=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# SSL/HTTPS (optional - for local HTTPS development)
USE_HTTPS=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# Run ./backend/generate_certs.sh (Linux/Mac) or generate_certs.ps1 (Windows)
# to create self-signed certificates for development HTTPS.
